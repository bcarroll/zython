diff --git a/raspberrypi/Makefile b/raspberrypi/Makefile
--- a/raspberrypi/Makefile
+++ b/raspberrypi/Makefile
@@ -9,6 +9,10 @@ QSTR_DEFS = qstrdefsport.h
 
 FROZEN_DIR ?= scripts
 # FROZEN_MPY_DIR ?= modules
+ifeq ($(MICROPY_BOOT_FROZEN_MPY),1)
+FROZEN_DIR :=
+FROZEN_MPY_DIR ?= fs
+endif
 
 # include py core make definitions
 include $(TOP)/py/py.mk
@@ -47,6 +51,8 @@ ASFLAGS += $(CFLAGS_FPU)
 #Debugging/Optimization
 ifeq ($(DEBUG), 1)
 CFLAGS += -O0 -gdwarf-2
+else ifeq ($(PERF),1)
+CFLAGS += -O2 -DNDEBUG
 else
 CFLAGS += -Os -DNDEBUG
 endif
@@ -151,7 +157,7 @@ USBLIB = $(BUILD)/$(CSUDLIB)
 $(USBLIB): 
 	$(ECHO) "MAKE $@"
 	$(Q)$(MKDIR) -p $(BUILD)/$(USBHOST_DIR)
-	$(Q)$(MAKE) -s -C $(USBHOST_DIR) driver CONFIG=FINAL TYPE=DRIVER TARGET=$(BOARD) GNU=$(CROSS_COMPILE) BUILD=../$(BUILD)/$(USBHOST_DIR)/ LIBNAME=../$(USBLIB) COPT="-Os $(CFLAGS_FPU)"
+	$(Q)$(MAKE) -s -C $(USBHOST_DIR) driver CONFIG=FINAL TYPE=DRIVER TARGET=$(BOARD) GNU=$(CROSS_COMPILE) BUILD=../$(BUILD)/$(USBHOST_DIR)/ LIBNAME=../$(USBLIB) COPT="$(if $(filter 1,$(PERF)),-O2,-Os) $(CFLAGS_FPU)"
 
 endif
 
@@ -161,6 +167,8 @@ SRC_LIB += $(addprefix lib/,\
 	oofatfs/ffunicode.c \
 	)
 CFLAGS += -DMICROPY_MOUNT_SD_CARD=$(MICROPY_MOUNT_SD_CARD)
+CFLAGS += -DMICROPY_MOUNT_FIRST_PARTITION_ONLY=$(MICROPY_MOUNT_FIRST_PARTITION_ONLY)
+CFLAGS += -DMICROPY_BOOT_FROZEN_MPY=$(MICROPY_BOOT_FROZEN_MPY)
 
 # List of sources for qstr extraction
 SRC_QSTR += $(SRC_C) $(SRC_MOD) $(SRC_LIB)
@@ -182,6 +190,14 @@ $(INTERRUPT_SAFE_OBJECTS): CFLAGS += -mgeneral-regs-only
 # capture in py/stackctrl.c. Keep the warning enabled elsewhere.
 $(BUILD)/py/stackctrl.o: CFLAGS += -Wno-error=dangling-pointer
 
+# GCC 13 with -O2 also reports false positives in MicroPython's import-name
+# handling path. Keep them scoped to the affected core object.
+$(BUILD)/py/compile.o: CFLAGS += -Walloca-larger-than=4294967295 -Wno-error=maybe-uninitialized
+
+# GCC 13 also surfaces maybe-uninitialized false positives in the bundled
+# libm sources when this port is built with -O2.
+$(BUILD)/lib/libm/%.o: CFLAGS += -Wno-error=maybe-uninitialized
+
 
 ifneq ($(FROZEN_DIR),)
 # To use frozen source modules, put your .py files in a subdirectory (eg scripts/)
diff --git a/raspberrypi/main.c b/raspberrypi/main.c
--- a/raspberrypi/main.c
+++ b/raspberrypi/main.c
@@ -61,7 +61,8 @@ char *arm_boot_tag_cmdline(const int32_t *ptr) {
 
 STATIC bool init_sdcard_fs(void) {
     bool first_part = true;
-    for (int part_num = 1; part_num <= 4; ++part_num) {
+    const int max_partitions = MICROPY_MOUNT_FIRST_PARTITION_ONLY ? 1 : 4;
+    for (int part_num = 1; part_num <= max_partitions; ++part_num) {
         // create vfs object
         fs_user_mount_t *vfs_fat = m_new_obj_maybe(fs_user_mount_t);
         mp_vfs_mount_t *vfs = m_new_obj_maybe(mp_vfs_mount_t);
@@ -181,26 +182,19 @@ int arm_main(uint32_t r0, uint32_t id, const int32_t *atag) {
         if (!use_qemu && mounted_sdcard) {
             mp_obj_list_append(mp_sys_path, MP_OBJ_NEW_QSTR(MP_QSTR__slash_sd_slash_lib));
             mp_obj_list_append(mp_sys_path, MP_OBJ_NEW_QSTR(MP_QSTR__slash_sd));
-            if (pyexec_mode_kind == PYEXEC_MODE_FRIENDLY_REPL) {
-                mp_import_stat_t stat;
-                // Run the boot config script from the current directory.
-                const char boot_py[] = "boot.py";
-                stat = mp_import_stat(boot_py);
-                if (stat == MP_IMPORT_STAT_FILE) {
-                    int ret = pyexec_file(boot_py);
-                    if (!ret) {
-                        printf("%s: execution error\n\r", boot_py);
-                    }
-                }
-                // Run the main script from the current directory.
-                const char main_py[] = "main.py";
-                stat = mp_import_stat(main_py);
-                if (stat == MP_IMPORT_STAT_FILE) {
-                    int ret = pyexec_file(main_py);
-                    if (!ret) {
-                        printf("%s: execution error\n\r", main_py);
-                    }
-                }
+        }
+
+        if (pyexec_mode_kind == PYEXEC_MODE_FRIENDLY_REPL) {
+            const char boot_py[] = "boot.py";
+            int ret = pyexec_file_if_exists(boot_py);
+            if (!ret) {
+                printf("%s: execution error\n\r", boot_py);
+            }
+
+            const char main_py[] = "main.py";
+            ret = pyexec_file_if_exists(main_py);
+            if (!ret) {
+                printf("%s: execution error\n\r", main_py);
             }
         }
 #endif
diff --git a/raspberrypi/mpconfigport.h b/raspberrypi/mpconfigport.h
