+# GCC 13+ rejects ARM interrupt handlers under hard-float unless the affected
+# translation units are compiled without FP register use.
+INTERRUPT_SAFE_OBJECTS := \
+	$(BUILD)/rpi.o \
+	$(BUILD)/arm_exceptions.o \
+	$(BUILD)/arm_ex_handler_weak.o
 
